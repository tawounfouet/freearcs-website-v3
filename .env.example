# Freearcs Pharma Services - Environment Variables
# Copy to .env and fill in values
# Vite automatically loads .env files

# === Application ===
# Enable health check endpoints (true/false)
ENABLE_HEALTH_CHECK=false

# === Analytics ===
# PostHog configuration (optional - see GDPR compliance plan)
# VITE_POSTHOG_KEY=phc_your_key_here
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# === API (when backend implemented) ===
# VITE_API_URL=https://api.freearcs-pharma.com

# === Feature Flags ===
# VITE_MAINTENANCE_MODE=false